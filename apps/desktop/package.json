{
  "name": "@kmux/desktop",
  "version": "0.3.12",
  "private": true,
  "description": "Keyboard-first terminal workspace manager for macOS",
  "author": "kmux contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkd927/kmux.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.ts",
    "build": "electron-vite build --config electron.vite.config.ts",
    "dist:mac": "electron-builder --config electron-builder.yml --mac --publish never",
    "dist:linux": "electron-builder --config electron-builder.yml --linux AppImage --publish never",
    "preview": "electron-vite preview --config electron.vite.config.ts"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.4",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "plist": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "@napi-rs/keyring-linux-arm64-gnu": "1.3.0",
    "@napi-rs/keyring-linux-x64-gnu": "1.3.0"
  }
}
