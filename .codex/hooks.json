{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/zsh -lc 'repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); exec /usr/bin/python3 \"$repo_root/.codex/hooks/stop_continue.py\"'",
            "timeout": 1200
          }
        ]
      }
    ]
  }
}
